# ENV
IN_PRODUCTION=false

# PRIVY
NEXT_PUBLIC_PRIVY_APP_ID=x
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
# Optional backwards-compatible alias if you still use it elsewhere
# NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:8080
NEXT_PUBLIC_PRIVY_CUSTOM_OAUTH_REDIRECT_URL=
NEXT_PUBLIC_PRIVY_ENABLE_PASSKEY_LOGIN=false

# SECURITY / CSP
# Comma-separated extra origins/sources, only if your production setup needs them.
NEXT_PUBLIC_CSP_EXTRA_SCRIPT_SRC=
NEXT_PUBLIC_CSP_EXTRA_STYLE_SRC=
NEXT_PUBLIC_CSP_EXTRA_FONT_SRC=
NEXT_PUBLIC_CSP_EXTRA_CONNECT_SRC=
NEXT_PUBLIC_CSP_EXTRA_FRAME_SRC=
NEXT_PUBLIC_CSP_EXTRA_IMG_SRC=
NEXT_PUBLIC_CSP_EXTRA_WORKER_SRC=
NEXT_PUBLIC_CSP_REPORT_URI=
NEXT_PUBLIC_CSP_REPORT_ONLY=false

# CHAIN
NEXT_PUBLIC_CHAIN_NAME=x
NEXT_PUBLIC_FACTORY_ADDRESS=x
NEXT_PUBLIC_FAUCET_ADDRESS=x
NEXT_PUBLIC_ZAPPER_ADDRESS=x

# PAYMASTER
# To find paymaster address, check "chains" in config at https://config.internal.citizenwallet.xyz/v4/communities.json
NEXT_PUBLIC_ENGINE_URL=x
NEXT_PUBLIC_PAYMASTER_ADDRESS=x
NEXT_PUBLIC_TOKEN_ADDRESS=x
NEXT_PUBLIC_HONEY_ADDRESS=x
NEXT_PUBLIC_WEB_BURNER_PASSWORD=x
NEXT_PUBLIC_BYUSD_ADDRESS=x

# GOOGLE MAPS
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=x
NEXT_PUBLIC_MAP_ID=x

# IDLE TIMER
NEXT_PUBLIC_IDLE_TIMER_TIMEOUT_SECONDS=600
NEXT_PUBLIC_IDLE_TIMER_PROMPT_SECONDS=60

#ZAPPERS
NEXT_PUBLIC_BYUSD_ADDRESS=x
NEXT_PUBLIC_ZAPPER_ADDRESS=x
NEXT_PUBLIC_HONEY_DECIMALS=18
NEXT_PUBLIC_BACKING_ASSETS=
