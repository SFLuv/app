#SERVER
PORT=8080
IN_PRODUCTION=false
APP_BASE_URL=http://localhost:3000
# Optional explicit browser allowlist for API CORS. Falls back to APP_BASE_URL,
# plus localhost defaults when IN_PRODUCTION=false.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

#DATABASE
DB_TYPE=x
DB_BASE_URL= # falls back to DB_URL, then localhost:5432
APP_DB_NAME=app
BOT_DB_NAME=bot
DB_USER= # only needed for postgres
DB_PASSWORD= # only needed for postgres

#AUTH
ADMIN_KEY=x

#CHAIN
# Client blockchain config is loaded at backend boot from Citizen Wallet config.
# The backend fetches the whole community config from the communities API at
# ${CITIZEN_WALLET_COMMUNITY_API_URL}/${CITIZEN_WALLET_COMMUNITY_ALIAS} and uses
# the config embedded in the response's "json" field.
# If remote config is unavailable, CLIENT_CONFIG_FALLBACK_PATH is read.
# If neither source is available, the backend fails to boot.
# Set CLIENT_CONFIG_LOCAL_ONLY=true to skip Citizen Wallet entirely and load
# CLIENT_CONFIG_FALLBACK_PATH directly for local fork/migration testing.
#
# Alias must be exact. Note both of these SFLuv communities exist:
#   wallet.berachain.sfluv.org -> "SFLUV Community" (Berachain, chain 80094)
#   wallet.sfluv.org           -> "SFLUV Community (Polygon)"
CITIZEN_WALLET_COMMUNITY_ALIAS=wallet.berachain.sfluv.org
# Optional overrides:
# CITIZEN_WALLET_COMMUNITY_API_URL=  # communities API base (default https://my.citizenwallet.xyz/api/communities)
# CITIZEN_WALLET_CONFIG_URL=         # full URL to a single raw-config file; bypasses the communities API when set
CLIENT_CONFIG_LOCAL_ONLY=false
CLIENT_CONFIG_FALLBACK_PATH=community-config.json

# Legacy env values still used by transitional scripts/ops. Runtime client-facing
# blockchain values should come from the boot-loaded Citizen Wallet config.
TOKEN_ID=x
UNDERLYING_TOKEN_ID=x
# Legacy backend token multiplier used for payouts, W9 limits, and formatting.
# /config derives ERC-20 decimal places from this value for the mobile app.
TOKEN_DECIMALS=1000000000000000000
# Full JSON-RPC node URL. Also served to clients as /config.extras.rpc_url and
# used by web/mobile for READS (eth_getCode/eth_getBalance/eth_getStorageAt),
# which the Citizen Wallet engine does not support. The AA bundler/paymaster
# still uses the engine (chains[].node.url/v1/rpc/{paymaster}). Must be a real
# node, not the engine. CLIENT_READ_RPC_URL overrides this for the served value.
RPC_URL=x

# Chain-specific extras that Citizen Wallet config does not model yet. These are
# added under /config.extras at backend boot and should be left empty on chains
# where the integration is unavailable. If BYUSD/HONEY are present in the
# Citizen Wallet tokens map, that config remains authoritative and these token
# extras are omitted from the served payload.
BACKING_ASSETS=
HONEY_ADDRESS=
HONEY_DECIMALS=
BYUSD_ADDRESS=
BYUSD_DECIMALS=
ZAPPER_ADDRESS=
FAUCET_ADDRESS=
BOT_KEY=x
BOT_ADDRESS=x
ADMIN_ADDRESS=x
REDEEMER_ADMIN_KEY=x
REDEEMER_ADMIN_ADDRESS=x

#PRIVY
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_VKEY=""
PRIVY_API_BASE_URL=https://auth.privy.io/api/v1

#MAILGUN
MAILGUN_API_KEY=x
MAILGUN_DOMAIN=mail.sfluv.org
# Set NOTIFICATION_TEST_MODE=true to disable Mailgun/Expo sends and write
# rendered notifications under backend/test-notifications by default.
NOTIFICATION_TEST_MODE=false
NOTIFICATION_TEST_OUTPUT_DIR=
AFFILIATE_ADMIN_EMAIL=admin@sfluv.org
PROPOSER_ADMIN_EMAIL=admin@sfluv.org
IMPROVER_ADMIN_EMAIL=admin@sfluv.org
WORKFLOW_ADMIN_EMAIL=admin@sfluv.org

#WORKFLOW
# Stored workflow photo upload byte limit. Multipart request limit is 2x this value.
WORKFLOW_PHOTO_UPLOAD_MAX_BYTES=4194304

#PONDER
PONDER_SERVER_BASE_URL=http://localhost:42069
PONDER_KEY=x
PONDER_CALLBACK_URL=http://localhost:8080/ponder/callback

# MOBILE CLIENT CONFIG + VERSION POLICY
PUBLIC_BACKEND_URL=http://localhost:8080
CLIENT_CONFIG_VERSION=local
CLIENT_DEFAULT_VERSION=1.0.0
CLIENT_DEFAULT_BUILD=1
CLIENT_MIN_VERSION=1.0.0
CLIENT_MIN_BUILD=1
CLIENT_MIN_VERSION_IOS=1.0.0
CLIENT_MIN_BUILD_IOS=1
CLIENT_MIN_VERSION_ANDROID=1.0.0
CLIENT_MIN_BUILD_ANDROID=1
CLIENT_RECOMMENDED_VERSION=1.0.0
CLIENT_RECOMMENDED_BUILD=1
CLIENT_RECOMMENDED_VERSION_IOS=1.0.0
CLIENT_RECOMMENDED_BUILD_IOS=1
CLIENT_RECOMMENDED_VERSION_ANDROID=1.0.0
CLIENT_RECOMMENDED_BUILD_ANDROID=1
CLIENT_CURRENT_VERSION=1.0.0
CLIENT_CURRENT_BUILD=1
CLIENT_CURRENT_VERSION_IOS=1.0.0
CLIENT_CURRENT_BUILD_IOS=1
CLIENT_CURRENT_VERSION_ANDROID=1.0.0
CLIENT_CURRENT_BUILD_ANDROID=1
CLIENT_UPDATE_URL=
CLIENT_UPDATE_URL_IOS=
CLIENT_UPDATE_URL_ANDROID=
CLIENT_VERSION_MESSAGE=
CLIENT_UPDATE_REQUIRED_MESSAGE=An SFLUV Wallet update is required.
CLIENT_UPDATE_RECOMMENDED_MESSAGE=A newer SFLUV Wallet update is available.
CLIENT_UNSUPPORTED_PLATFORM_MESSAGE=This app version is not supported.
CLIENT_MAINTENANCE=false
CLIENT_MAINTENANCE_MESSAGE=SFLUV is temporarily unavailable while maintenance is in progress.
CLIENT_DYNAMIC_CONFIG_REQUIRED=true
CLIENT_CELO_REQUIRED=false
CLIENT_COMMUNITY_NAME=SFLUV Community
CLIENT_COMMUNITY_ALIAS=wallet.berachain.sfluv.org
CLIENT_COMMUNITY_CUSTOM_DOMAIN=wallet.sfluv.org
CLIENT_COMMUNITY_LOGO=https://assets.citizenwallet.xyz/wallet-config/_images/sfluv.svg
CLIENT_COMMUNITY_PROFILE_ADDRESS=0x05e2Fb34b4548990F96B3ba422eA3EF49D5dAa99
CHAIN_ID=80094
CHAIN_NAME=Berachain
NATIVE_CURRENCY_NAME=BERA
NATIVE_CURRENCY_SYMBOL=BERA
NATIVE_CURRENCY_DECIMALS=18
TOKEN_NAME=SFLUV
TOKEN_SYMBOL=SFLUV
ENGINE_RPC_URL=https://80094.engine.citizenwallet.xyz
ENGINE_WS_URL=wss://80094.engine.citizenwallet.xyz
EXPLORER_NAME=Berascan
EXPLORER_URL=https://berascan.com
# Do not set CITIZEN_WALLET_CONFIG_URL to a per-community ${alias}.json file on
# this host: those return HTTP 403, and "wallet.sfluv.org" is the Polygon
# community, not Berachain. Config is loaded via the communities API + alias above.
IPFS_URL=https://ipfs.internal.citizenwallet.xyz
FEATURE_SENDS_ENABLED=true
FEATURE_REDEMPTIONS_ENABLED=true
FEATURE_WORKFLOW_PAYOUTS_ENABLED=true
FEATURE_MERCHANT_PAYMENTS_ENABLED=true

#W9
PAID_ADMIN_ADDRESSES=
W9_ADMIN_EMAIL=admin@sfluv.org
W9_SUBMISSION_URL=https://sfluv.org/submit-w9/
# Optional: override W9 threshold for testing (either in wei or whole SFLUV).
# W9_LIMIT_WEI=
# W9_LIMIT_SFLUV=
# Optional TLS (local HTTPS)
# TLS_CERT_FILE=/path/to/localhost.crt
# TLS_KEY_FILE=/path/to/localhost.key
# TLS_PORT=8443
